{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "nations-2b049",
          "appId": "1:362244352362:android:29c9b457c4fb8fe5c9dd13",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "nations-2b049",
          "configurations": {
            "android": "1:362244352362:android:29c9b457c4fb8fe5c9dd13",
            "web": "1:362244352362:web:a811525bfd3ee5fcc9dd13",
            "windows": "1:362244352362:web:48ce39621fda0d3fc9dd13"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/{canvaskit,assets,icons}/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
